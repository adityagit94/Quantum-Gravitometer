# Local research datasets — NOT part of the package (often >100 MB, which
# GitHub rejects). Keep these out of the repo; use external storage / git-lfs.
Datasets/

# User-provided datasets are not committed, but keep the small bundled
# fixtures that the test suite and the GUI "Use sample" button depend on.
data/raw/*
data/processed/
!data/raw/sg_sample/
!data/raw/real_ifo_template.csv
